<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{0} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      Capture EVERYTHING (harness + all three node containers + testcontainers) to a single plain
      UTF-8 file, written one full line at a time (immune to terminal ANSI mangling). Truncated at
      JVM start; cleaned by `mvn clean`. Tail during a run with: tail -f target/axon-cluster-it.log
    -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>target/axon-cluster-it.log</file>
        <append>false</append>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{0} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="node1" level="INFO"/>
    <logger name="node2" level="INFO"/>
    <logger name="node3" level="INFO"/>
    <logger name="cluster-it" level="INFO"/>
    <logger name="org.testcontainers" level="INFO"/>
    <logger name="com.github.dockerjava" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
